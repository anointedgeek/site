---
import Base from '../layouts/Base.astro';
---

<Base title="Projects" description="Things I've built.">
  <div class="projects">
    <h1 class="page-label">projects</h1>
    <p class="coming-soon">more here soon.</p>
  </div>
</Base>

<style>
  .page-label {
    font-family: var(--mono);
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--muted);
    letter-spacing: 0.06em;
    margin: 0 0 2.5rem;
  }

  .coming-soon {
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
  }
</style>
