---
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/500.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'anointedgeek',
  description = 'Writing about technology, faith, and the things worth building.',
} = Astro.props;

const currentPath = Astro.url.pathname;
const pageTitle = title === 'anointedgeek' ? title : `${title} — anointedgeek`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="anointedgeek" href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-wrap">
      <header>
        <a href="/" class="logo">
          a<span class="dot">·</span>g
        </a>
        <nav>
          <a
            href="/writing"
            class:list={[{ active: currentPath.startsWith('/writing') }]}
          >writing</a>
          <span class="sep">·</span>
          <a
            href="/about"
            class:list={[{ active: currentPath === '/about' || currentPath === '/about/' }]}
          >about</a>
          <span class="sep">·</span>
          <a href="/rss.xml" class="rss-link" target="_blank" rel="noopener">rss ↗</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer>
        <span class="footer-name">jeff strahl</span>
        <span class="footer-tagline">no tracking. no ads. just words.</span>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  /* ── Variables ──────────────────────────────────────── */
  :root {
    --bg:       #FAF9F7;
    --text:     #1C1917;
    --muted:    #78716C;
    --accent:   #BA7517;
    --border:   #E7E5E4;
    --max-w:    660px;
    --mono:     'JetBrains Mono', 'Courier New', monospace;
    --serif:    'Lora', Georgia, serif;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg:     #141110;
      --text:   #E7E5E4;
      --muted:  #78716C;
      --accent: #FAC775;
      --border: #292524;
    }
  }

  /* ── Reset ──────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }

  html { font-size: 16px; }

  body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--serif);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img { max-width: 100%; }

  /* ── Layout ─────────────────────────────────────────── */
  .site-wrap {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ─────────────────────────────────────────── */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .logo {
    font-family: var(--mono);
    font-size: 1.75rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo:hover { color: var(--text); }

  .dot { color: var(--accent); }

  .logo-domain {
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--muted);
    letter-spacing: 0;
  }

  /* ── Nav ────────────────────────────────────────────── */
  nav {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
    padding-top: 4px;
  }

  nav a {
    color: var(--muted);
    transition: color 0.15s ease;
  }

  nav a:hover { color: var(--text); }

  nav a.active {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  nav .sep {
    color: var(--border);
    user-select: none;
  }

  nav .rss-link {
    color: var(--accent);
  }

  nav .rss-link:hover {
    color: var(--text);
  }

  /* ── Main ───────────────────────────────────────────── */
  main {
    min-height: 60vh;
  }

  /* ── Footer ─────────────────────────────────────────── */
  footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 2rem 0 2.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .footer-name { white-space: nowrap; }

  .footer-link {
    color: var(--accent);
    text-decoration: none;
  }

  .footer-link:hover { color: var(--text); }

  .footer-tagline {
    text-align: right;
    white-space: nowrap;
  }

  /* ── Base Typography ────────────────────────────────── */
  h1, h2, h3, h4 {
    font-family: var(--serif);
    font-weight: 500;
    line-height: 1.3;
    margin: 0 0 1rem;
  }

  p { margin: 0 0 1.25rem; }

  /* ── Prose (blog post content) ──────────────────────── */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .prose p { margin: 0 0 1.4rem; }

  .prose h2 {
    font-size: 1.375rem;
    margin: 2.5rem 0 0.875rem;
  }

  .prose h3 {
    font-size: 1.125rem;
    margin: 2rem 0 0.75rem;
  }

  .prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }

  .prose a:hover { color: var(--text); }

  .prose blockquote {
    border-left: 3px solid var(--accent);
    margin: 1.75rem 0;
    padding: 0.125rem 0 0.125rem 1.25rem;
    color: var(--muted);
    font-style: italic;
  }

  .prose blockquote p { margin-bottom: 0; }

  .prose code {
    font-family: var(--mono);
    font-size: 0.875em;
    background: var(--border);
    padding: 0.1em 0.4em;
    border-radius: 3px;
  }

  .prose pre {
    background: #1C1917;
    color: #E7E5E4;
    padding: 1.25rem 1.5rem;
    border-radius: 4px;
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 1.5rem 0;
  }

  .prose pre code {
    background: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
    border-radius: 0;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.5rem;
    margin: 0 0 1.4rem;
  }

  .prose li { margin-bottom: 0.375rem; }

  .prose img {
    max-width: 100%;
    border-radius: 4px;
    margin: 1.5rem 0;
  }

  .prose strong { font-weight: 600; }

  /* ── Utilities ──────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
