---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(d: Date) {
  const y = d.getUTCFullYear();
  const m = String(d.getUTCMonth() + 1).padStart(2, '0');
  const day = String(d.getUTCDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
}
---

<Base
  title="anointedgeek"
  description="Writing about technology, faith, and the things worth building."
>
  <div class="home">
    {posts.length === 0 ? (
      <p class="empty">something is coming. check back.</p>
    ) : (
      <div class="post-section">
        <p class="section-label">recent writing</p>
        <ul class="post-list">
          {posts.map((post, i) => (
            <li class:list={['post-item', { 'post-item--latest': i === 0 }]}>
              <a href={`/writing/${post.id}`} class="post-link">
                <h2 class="post-title">{post.data.title}</h2>
                <div class="post-meta">
                  <time class="post-date" datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <>
                      <span class="meta-sep" aria-hidden="true">·</span>
                      <span class="post-tags">{post.data.tags.join('·')}</span>
                    </>
                  )}
                </div>
                {post.data.description && (
                  <p class="post-excerpt">{post.data.description}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</Base>

<style>
  .empty {
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--muted);
    padding: 1rem 0;
  }

  .section-label {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    margin: 0 0 1.25rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--border);
  }

  .post-item--latest {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin-left: -1rem;
  }

  .post-link {
    display: block;
    padding: 1rem 0;
    color: inherit;
    text-decoration: none;
  }

  .post-item:first-child .post-link {
    padding-top: 0;
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-title {
    font-family: var(--serif);
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: 1.4;
    margin: 0 0 0.3rem;
    transition: color 0.15s ease;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
  }

  .meta-sep { user-select: none; }

  .post-excerpt {
    margin: 0.5rem 0 0;
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.6;
  }
</style>
